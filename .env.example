DATABASE_URL=sqlite:///./leaf.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_VISION_MODEL=gemma4:e4b
DEBUG=false

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Voice features
# STT: faster-whisper descarga su modelo solo en ~/.cache/huggingface al primer uso
# TTS: Piper se descarga automáticamente en ./models/ al iniciar el servidor
WHISPER_MODEL_SIZE=small                              # fallback STT si phi4 no carga
PIPER_VOICE_PATH=models/es_ES-davefx-medium.onnx
OLLAMA_VOICE_MODEL=phi4                               # LLM para razonar y llamar herramientas
PHI4_VOICE_MODEL=microsoft/Phi-4-multimodal-instruct  # STT multimodal (audio directo)
