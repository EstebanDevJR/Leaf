DATABASE_URL=sqlite:///./leaf.db
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_VISION_MODEL=gemma4:e4b
DEBUG=false

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Voz — STT + LLM: Groq (gratis). TTS: Google TTS (gratis, sin key)
# Regístrate en console.groq.com para obtener la API key
GROQ_API_KEY=
GROQ_VOICE_MODEL=llama-3.3-70b-versatile   # o llama-3.1-8b-instant para más velocidad
